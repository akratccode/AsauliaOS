# ---------- Requeridas por lib/env.ts (el dev server no arranca sin estas) ----------

# Supabase (pegar las que imprime `supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres directo para Drizzle (el de Supabase local por defecto)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---------- Opcionales (se activan en fases posteriores) ----------

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_CONNECT_CLIENT_ID=

# Resend
RESEND_API_KEY=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Shopify
SHOPIFY_APP_API_KEY=
SHOPIFY_APP_API_SECRET=
SHOPIFY_APP_SCOPES=read_orders,read_products
SHOPIFY_WEBHOOK_SECRET=

# Stripe Sales (integración de ventas)
STRIPE_SALES_SECRET_KEY=
STRIPE_SALES_WEBHOOK_SECRET=

# Integrations encryption
INTEGRATIONS_ENCRYPTION_KEY=

# Cron secret (Vercel cron)
CRON_SECRET=

# Upstash rate limit (opcional, no-op si está vacío)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
